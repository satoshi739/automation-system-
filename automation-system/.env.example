# =====================================================
# UPJ ダッシュボード 環境変数設定
# このファイルをコピーして .env にリネームして使う
# .env は絶対にGitにコミットしない
# =====================================================

# ── AI ────────────────────────────────────────────
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=

# OpenAI（TTS・GPT連携）
OPENAI_API_KEY=

# Google AI Studio（Veo動画生成・Gemini）
# https://aistudio.google.com/app/apikey で取得（無料枠あり）
GOOGLE_AI_STUDIO_API_KEY=

# ── ダッシュボード認証 ──────────────────────────────
# ADMIN_USER + ADMIN_PASSWORD が主認証（両方設定で有効）
ADMIN_USER=                    # 管理画面ログイン名
ADMIN_PASSWORD=                # 管理画面パスワード
SESSION_SECRET=                # セッション署名キー（空なら起動時自動生成）
FLASK_DEBUG=false              # true にすると Flask デバッグモード有効
# 後方互換：DASHBOARD_PASSWORD のみ設定でもシンプル認証が有効
DASHBOARD_PASSWORD=

# ── 共通設定 ──────────────────────────────────────
DRY_RUN=false                  # true にすると実際に投稿せずログだけ出る（テスト用）
OWNER_LINE_USER_ID=            # 朝のサマリー受信用（自分のLINE user_id）
NOTIFY_EMAIL=                  # エスカレーション通知先メール

# ── アラート専用LINEチャンネル ────────────────────
# scheduler停止・APIエラー等のシステムアラートを送るチャンネル
ALERT_LINE_CHANNEL_ACCESS_TOKEN=
ALERT_LINE_CHANNEL_SECRET=

# ── Railway（自動デプロイ・環境同期）────────────────
RAILWAY_PUBLIC_DOMAIN=         # 例: your-app.up.railway.app
RAILWAY_API_TOKEN=             # Railway ダッシュボード > Account Settings > Tokens
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=

# ── 財務・決済 ────────────────────────────────────
STRIPE_SECRET_KEY=             # https://dashboard.stripe.com/apikeys
TOKEN_ENCRYPTION_KEY=          # Fernet対称鍵（python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）

# ════════════════════════════════════════════════════
# ── UPJ（Universal Planet Japan）────────────────────
# ════════════════════════════════════════════════════

# Instagram（Meta Graph API）
UPJAPAN_META_ACCESS_TOKEN=
UPJAPAN_INSTAGRAM_ACCOUNT_ID=     # IG ビジネスアカウントの数値ID

# Threads
UPJAPAN_THREADS_USER_ID=

# Facebook ページ
UPJAPAN_FB_PAGE_ID=
UPJAPAN_FB_PAGE_TOKEN=

# Twitter / X
UPJAPAN_TWITTER_API_KEY=
UPJAPAN_TWITTER_API_SECRET=
UPJAPAN_TWITTER_ACCESS_TOKEN=
UPJAPAN_TWITTER_ACCESS_SECRET=

# WordPress
UPJAPAN_WP_URL=https://upjapan.co.jp
UPJAPAN_WP_USER=
UPJAPAN_WP_APP_PASSWORD=

# Google Analytics 4 / Search Console
UPJAPAN_GA4_PROPERTY_ID=
UPJAPAN_GSC_SITE_URL=https://upjapan.co.jp/

