# ════════════════════════════════════════════════════
# ── Google 共通 ─────────────────────────────────────
# ════════════════════════════════════════════════════
# サービスアカウントの credentials.json を automation-system/ に配置
GOOGLE_DRIVE_FOLDER_ID=        # Google Drive 素材書き出し先フォルダID

# ════════════════════════════════════════════════════
# ── Google Business Profile (MEO) ───────────────────
# ════════════════════════════════════════════════════
# OAuth2 リフレッシュトークン（推奨）
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REFRESH_TOKEN=
# オプション: アカウント名を固定する場合（例: accounts/123456789）
# GBP_ACCOUNT_NAME=

# ── デフォルトLINEチャンネル（フォールバック用）────────
# 特定ブランドのチャンネルが未設定のときのフォールバック
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── メール自動返信（Gmail）────────────────────────
FROM_EMAIL=
FROM_EMAIL_PASSWORD=            # Gmailアプリパスワード
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
